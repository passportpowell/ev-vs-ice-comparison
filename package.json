{
  "name": "ev-ice-intelligence-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive EV vs petrol/diesel comparison lab with a Python data pipeline, SQL artifact, REST API routes, and a Vercel-ready React dashboard.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "data:build": "python -m pipeline.ev_ice_pipeline.build",
    "data:test": "pytest tests/python",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run data:build && npm run data:test && npm run lint && npm run test && npm run security:audit && npm run build"
  },
  "dependencies": {
    "lucide-react": "1.14.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "overrides": {
    "postcss": "8.5.13"
  },
  "engines": {
    "node": ">=22.0.0",
    "python": ">=3.11"
  }
}
